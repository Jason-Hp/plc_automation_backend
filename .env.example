# App
APP_NAME=PLC Automation API
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/plc_automation

# JWT
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=3

# SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
SMTP_FROM=info@plcautomationgroup.com
ADMIN_EMAIL=sales@plcautomat.com
QUOTE_AND_ENQUIRY_EMAIL=quotes@plcautomat.com
HR_EMAIL=hr@plcautomat.com

# Admin / Updater accounts
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
UPDATER_1_USERNAME=updater1
UPDATER_1_PASSWORD=change_me
UPDATER_2_USERNAME=updater2
UPDATER_2_PASSWORD=change_me

# Local storage and logs
UPLOAD_DIR=./uploads
WEB_LOG_LOCATION=./logs/web_logs
WARN_LOG_LOCATION=./logs/warn_logs
ERROR_LOG_LOCATION=./logs/error_logs
ENQUIRY_LOG_LOCATION=./logs/enquiry_logs
ADMIN_LOG_LOCATION=./logs/admin_logs

# Semantic search integrations
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=

# Optional AWS S3 storage (leave empty to use local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
AWS_CLOUDFRONT_DOMAIN=
